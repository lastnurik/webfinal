<%- include('../layouts/main', { title: 'Post Details', body: `
  <article class="mb-4" id="post-article">
    <div class="text-muted">Loading post...</div>
  </article>

  <section id="comments-section" class="mt-4" style="display: none;">
    <h2 class="h5 mb-3">Comments</h2>
    <div id="comments-list"></div>
    <div id="comment-form-wrap" class="mt-3" style="display: none;">
      <form id="comment-form">
        <input type="hidden" id="comment-post-id" />
        <div class="mb-2">
          <label for="comment-content" class="form-label">Add a comment</label>
          <textarea class="form-control" id="comment-content" rows="3" required></textarea>
        </div>
        <button type="submit" class="btn btn-primary">Post comment</button>
      </form>
    </div>
    <p id="comments-login-hint" class="text-muted small">Log in to leave a comment.</p>
  </section>
` }) %>
